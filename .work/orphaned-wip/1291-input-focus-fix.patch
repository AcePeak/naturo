+def _focus_target(backend, *, hwnd: Optional[int], window_title: Optional[str]) -> None:
+    """Focus the window the caller asked for, or fail loudly (#1291).
+
+    Input tools used to focus best-effort (``except Exception: pass``), so an
+    ``hwnd``/``window_title`` that did not resolve fell through and the
+    keystrokes landed in whatever window happened to be foreground — reported as
+    ``success:true``. That is the #957 silent-fallback class, and on the input
+    path it is a wrong-window *write*. Resolution now goes through the shared
+    :func:`require_hwnd`, so an unmatched selector raises ``WindowNotFoundError``
+    (mapped to a ``WINDOW_NOT_FOUND`` envelope) and nothing is typed.
+
+    Backends without HWND resolution (macOS/Linux) return ``0`` from
+    ``require_hwnd``; they keep focusing by the raw selector, which is the only
+    targeting they have.
+    """
+    resolved = require_hwnd(backend, window_title=window_title, hwnd=hwnd)
+    if resolved:
+        backend.focus_window(hwnd=resolved, title=None)
+    else:
+        backend.focus_window(hwnd=hwnd, title=window_title)
+
+
 def register_input_tools(server, _get_backend, _safe_tool):
     """Register input action MCP tools."""
 
